# SQLite database file — SHARED with BioCultDB (ADR-005: one file per federated unit)
SQLITE_DB_PATH=/data/unidade.sqlite

# Server ports
PUBLIC_PORT=4000
ADMIN_PORT=4001

# Admin users — JSON array of {username, passwordHash}
# Generate hash: node -e "const b=require('bcrypt'); b.hash('senha',10).then(h=>console.log(h))"
ADMIN_USERS=[{"username":"curador1","passwordHash":"$2b$10$SUBSTITUIR_HASH_AQUI"}]

# Audio file storage (Docker volume path)
AUDIO_STORAGE_PATH=/data/audio

# Scheduled acquisition (cron expression)
ACQUISITION_CRON_SCHEDULE=0 3 * * *

# Logging
LOG_LEVEL=info
NODE_ENV=development
