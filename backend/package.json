{
  "name": "etnotermos-backend",
  "version": "2.0.0",
  "description": "BioCultTermos — SKOS-XL vocabulary curation interface integrated with BioCultDB",
  "main": "src/start.js",
  "type": "module",
  "scripts": {
    "start": "node src/start.js",
    "dev:public": "node --watch src/contexts/public/server.js",
    "dev:admin": "node --watch src/contexts/admin/server.js",
    "start:public": "node src/contexts/public/server.js",
    "start:admin": "node src/contexts/admin/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:contract": "NODE_OPTIONS=--experimental-vm-modules jest tests/contract",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": [
    "ethnobotany",
    "skos-xl",
    "controlled-vocabulary",
    "mongodb",
    "biocultdb"
  ],
  "author": "BioCultTermos Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "mongodb": "^6.3.0",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.4",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
