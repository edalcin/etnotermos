<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="EtnoTermos — Vocabulário vernacular controlado para etnobotânica">
  <title>EtnoTermos — Vocabulário Vernacular Controlado</title>
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"
          integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+"
          crossorigin="anonymous" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js"
          integrity="sha384-9Ax3MmS9AClxJyd5/zafcXXjxmwFhZCdsT6HJoJjarvCaAkJlk5QDzjLJm+Wdx5F"
          crossorigin="anonymous" defer></script>
</head>
<body class="bg-forest-50 min-h-screen flex flex-col">

  <%- include('partials/header') %>

  <main class="flex-grow container mx-auto px-4 py-8">

    <!-- Hero / search -->
    <div class="bg-white rounded-lg shadow-md p-8 mb-8">
      <h1 class="text-3xl font-bold text-forest-700 mb-2">Vocabulário Vernacular Controlado</h1>
      <p class="text-gray-600 mb-6 max-w-2xl">
        Termos vernaculares de comunidades tradicionais organizados segundo o padrão
        ANSI/NISO Z39.19 e os Princípios CARE.
      </p>

      <div class="max-w-xl">
        <input
          type="search"
          name="q"
          placeholder="Buscar termos..."
          class="w-full px-5 py-3 text-base border-2 border-forest-300 rounded-lg
                 focus:outline-none focus:border-forest-600 transition-colors"
          hx-get="/concepts"
          hx-target="#results"
          hx-trigger="keyup changed delay:300ms, search"
          hx-include="this"
          autocomplete="off"
        >
      </div>
    </div>

    <!-- Semantic field cards -->
    <% if (typeof sourceGroups !== 'undefined' && sourceGroups.length > 0) { %>
    <h2 class="text-xl font-semibold text-gray-700 mb-4">Campos semânticos</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <%
        const FIELD_LABELS = {
          'comunidades.tipo': 'Tipos de Comunidades',
          'comunidades.plantas.nomeVernacular': 'Nomes Vernaculares de Plantas',
          'comunidades.plantas.tipoUso': 'Tipos de Uso de Plantas',
          'comunidades.atividadesEconomicas': 'Atividades Econômicas'
        };
      %>
      <% sourceGroups.forEach(group => { %>
      <a href="/concepts?sourceField=<%= encodeURIComponent(group.field) %>"
         class="bg-white rounded-lg shadow-sm border border-forest-100 p-5
                hover:border-forest-400 hover:shadow-md transition-all">
        <div class="text-lg font-semibold text-forest-700 mb-1">
          <%= FIELD_LABELS[group.field] || group.field %>
        </div>
        <div class="text-2xl font-bold text-gray-800"><%= group.count %></div>
        <div class="text-sm text-gray-500">termos ativos</div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <!-- HTMX search results (initially empty) -->
    <div id="results"></div>

  </main>

  <%- include('partials/footer') %>

</body>
</html>
