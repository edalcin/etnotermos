<%
  const STATUS_BADGE = {
    candidate: 'bg-yellow-100 text-yellow-800',
    active:    'bg-green-100 text-green-800',
    deprecated:'bg-gray-200 text-gray-600',
  };
  const STATUS_LABEL = {
    candidate: 'Candidato',
    active:    'Ativo',
    deprecated:'Depreciado',
  };
  const filterInclude = "[name='status'],[name='sourceField'],[name='q']";
  const nextSortDir = (col) => (sort === col && dir === 'asc') ? 'desc' : 'asc';
  const sortIndicator = (col) => sort === col ? (dir === 'desc' ? ' \u25bc' : ' \u25b2') : '';
%>

<!-- Keep the filter bar's hidden sort/dir fields in sync after an htmx swap
     (header-click requests set sort/dir explicitly via URL instead of through
     hx-include, to avoid sending stale+fresh duplicates). Skipped when this
     partial is included inline during the full page render, where list.ejs
     already renders these same-id fields once — avoids duplicate IDs. -->
<% if (isHtmxSwap) { %>
<input type="hidden" id="filter-sort" name="sort" value="<%= sort || '' %>" hx-swap-oob="true">
<input type="hidden" id="filter-dir" name="dir" value="<%= dir || '' %>" hx-swap-oob="true">
<% } %>

<% if (!concepts || concepts.length === 0) { %>
<div class="bg-white rounded-lg shadow-sm p-10 text-center text-gray-500">
  Nenhum termo encontrado.
</div>
<% } else { %>
<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-forest-600 text-white">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider">
          <button type="button"
                  hx-get="/concepts?sort=label&dir=<%= nextSortDir('label') %>"
                  hx-target="#concept-list"
                  hx-swap="innerHTML"
                  hx-include="<%= filterInclude %>"
                  class="flex items-center gap-1 hover:underline focus:outline-none">
            Termo<%= sortIndicator('label') %>
          </button>
        </th>
        <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider">
          <button type="button"
                  hx-get="/concepts?sort=status&dir=<%= nextSortDir('status') %>"
                  hx-target="#concept-list"
                  hx-swap="innerHTML"
                  hx-include="<%= filterInclude %>"
                  class="flex items-center gap-1 hover:underline focus:outline-none">
            Status<%= sortIndicator('status') %>
          </button>
        </th>
        <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider hidden sm:table-cell">
          Campos
        </th>
        <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider">Ação</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% concepts.forEach(concept => {
           const badgeClass = STATUS_BADGE[concept.status] || 'bg-gray-100 text-gray-700';
           const badgeLabel = STATUS_LABEL[concept.status] || concept.status;
      %>
      <tr class="hover:bg-forest-50 transition-colors">
        <td class="px-5 py-3 font-medium text-gray-800">
          <%= concept.prefLabels && concept.prefLabels[0] ? concept.prefLabels[0].literalForm : '(sem rótulo)' %>
        </td>
        <td class="px-5 py-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= badgeClass %>">
            <%= badgeLabel %>
          </span>
        </td>
        <td class="px-5 py-3 hidden sm:table-cell">
          <div class="flex flex-wrap gap-1">
            <% (concept.sourceFields || []).forEach(f => { %>
            <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded border border-gray-200">
              <%= f %>
            </span>
            <% }) %>
          </div>
        </td>
        <td class="px-5 py-3 text-right">
          <a href="/concepts/<%= concept.id %>"
             class="px-3 py-1 bg-forest-100 text-forest-700 rounded
                    hover:bg-forest-200 text-sm font-medium transition-colors">
            Editar
          </a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<% if (typeof pagination !== 'undefined' && pagination.total > pagination.limit) {
     const totalPages = Math.max(1, Math.ceil(pagination.total / pagination.limit));
     const rangeStart = (pagination.page - 1) * pagination.limit + 1;
     const rangeEnd = Math.min(pagination.page * pagination.limit, pagination.total);
     const includeFilters = "[name='status'],[name='sourceField'],[name='q'],[name='sort'],[name='dir']";
%>
<div class="mt-4 flex flex-wrap items-center justify-between gap-3 bg-white rounded-lg shadow-sm px-4 py-3">
  <p class="text-sm text-gray-600">
    Mostrando <%= rangeStart %>–<%= rangeEnd %> de <%= pagination.total %> termos
  </p>
  <div class="flex items-center gap-2">
    <button
      type="button"
      <% if (pagination.page <= 1) { %>disabled<% } %>
      hx-get="/concepts?page=<%= pagination.page - 1 %>"
      hx-target="#concept-list"
      hx-swap="innerHTML"
      hx-include="<%= includeFilters %>"
      class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50
             disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white">
      ← Anterior
    </button>
    <span class="px-2 text-sm text-gray-600">Página <%= pagination.page %> de <%= totalPages %></span>
    <button
      type="button"
      <% if (pagination.page >= totalPages) { %>disabled<% } %>
      hx-get="/concepts?page=<%= pagination.page + 1 %>"
      hx-target="#concept-list"
      hx-swap="innerHTML"
      hx-include="<%= includeFilters %>"
      class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50
             disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white">
      Próxima →
    </button>
  </div>
</div>
<% } %>
