<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auditoria | BioCultTermos Admin</title>
  <link href="/assets/styles.css" rel="stylesheet">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"
          integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+"
          crossorigin="anonymous" defer></script>
</head>
<body class="bg-forest-50 min-h-screen flex flex-col">
  <%- include('partials/header') %>
  <main class="flex-grow container mx-auto px-4 py-8">

    <div class="mb-6">
      <h1 class="text-3xl font-bold text-forest-700">Logs de Auditoria</h1>
      <p class="text-gray-600 mt-1">Rastreamento de operações administrativas — Conformidade com Princípios CARE</p>
    </div>

    <!-- Filters -->
    <form method="GET" action="/audit" class="bg-white rounded-lg shadow-sm p-4 mb-6 flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-48">
        <label class="block text-xs font-medium text-gray-600 mb-1">Responsável</label>
        <input
          type="text"
          name="responsible"
          value="<%= responsible %>"
          placeholder="Nome do usuário..."
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-forest-600"
        >
      </div>
      <div>
        <button type="submit" class="px-4 py-2 bg-forest-600 text-white rounded-lg text-sm hover:bg-forest-700 transition-colors">
          Filtrar
        </button>
        <a href="/audit" class="ml-2 px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors">
          Limpar
        </a>
      </div>
    </form>

    <% if (data.length === 0) { %>
    <div class="bg-white rounded-lg shadow-sm p-8 text-center text-gray-500">
      Nenhum log de auditoria encontrado.
    </div>
    <% } else { %>

    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-forest-600">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Data/Hora</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Conceito</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Campo</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Valor Anterior</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Novo Valor</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Responsável</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% data.forEach(entry => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600">
                <%= new Date(entry.timestamp).toLocaleString('pt-BR') %>
              </td>
              <td class="px-4 py-3 text-sm">
                <a href="/concepts/<%= entry.conceptId %>"
                   class="text-forest-600 hover:underline font-medium">
                  <%= entry.conceptLiteralForm || entry.conceptId %>
                </a>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700">
                <code class="bg-gray-100 px-1 rounded text-xs"><%= entry.field || '—' %></code>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500 max-w-xs truncate">
                <%= entry.previousValue != null ? JSON.stringify(entry.previousValue) : '—' %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-800 max-w-xs truncate">
                <%= entry.newValue != null ? JSON.stringify(entry.newValue) : '—' %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">
                <%= entry.responsible || 'Sistema' %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="bg-gray-50 px-4 py-3 flex items-center justify-between border-t border-gray-200">
        <div class="text-sm text-gray-600">
          Página <%= page %> de <%= totalPages %> &mdash; <%= total %> registros
        </div>
        <div class="flex gap-2">
          <% if (page > 1) { %>
          <a href="/audit?page=<%= page - 1 %>&limit=<%= limit %>&responsible=<%= responsible %>"
             class="px-3 py-1 border border-gray-300 rounded text-sm text-gray-700 bg-white hover:bg-gray-50">
            Anterior
          </a>
          <% } %>
          <% if (page < totalPages) { %>
          <a href="/audit?page=<%= page + 1 %>&limit=<%= limit %>&responsible=<%= responsible %>"
             class="px-3 py-1 border border-gray-300 rounded text-sm text-gray-700 bg-white hover:bg-gray-50">
            Próxima
          </a>
          <% } %>
        </div>
      </div>
    </div>

    <% } %>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-sm text-blue-800">
        <strong>Sobre Auditoria:</strong>
        Todos os registros são mantidos para garantir accountability e conformidade com os Princípios CARE
        (Benefício Coletivo, Autoridade de Controle, Responsabilidade, Ética).
      </p>
    </div>

  </main>
  <%- include('partials/footer') %>
</body>
</html>
