<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relacionamentos | BioCultTermos Admin</title>
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"
          integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+"
          crossorigin="anonymous" defer></script>
</head>
<body class="bg-forest-50 min-h-screen flex flex-col">
  <%- include('partials/header') %>

  <main class="flex-grow container mx-auto px-4 py-8">

    <div class="mb-6">
      <h1 class="text-3xl font-bold text-forest-700">Relacionamentos</h1>
      <p class="text-gray-600 mt-1">Hierarquias SKOS (broader/narrower) e associações (related) entre conceitos</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <div class="text-2xl font-bold text-forest-700"><%= stats.withAnyRelation %></div>
        <div class="text-sm text-gray-600 mt-1">Com relacionamento</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <div class="text-2xl font-bold text-blue-600"><%= stats.totalBroader %></div>
        <div class="text-sm text-gray-600 mt-1">Vínculos broader</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <div class="text-2xl font-bold text-indigo-600"><%= stats.totalNarrower %></div>
        <div class="text-sm text-gray-600 mt-1">Vínculos narrower</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <div class="text-2xl font-bold text-purple-600"><%= stats.totalRelated %></div>
        <div class="text-sm text-gray-600 mt-1">Vínculos related</div>
      </div>
    </div>

    <% if (concepts.length === 0) { %>
    <div class="bg-white rounded-lg shadow-sm p-8 text-center text-gray-500">
      Nenhum conceito com relacionamentos definidos ainda.
      <p class="text-sm mt-2">
        Edite um conceito para adicionar relações broader, narrower ou related.
      </p>
    </div>
    <% } else { %>

    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
        <span class="text-sm text-gray-600">Exibindo até 100 conceitos com relacionamentos</span>
        <a href="/concepts" class="text-sm text-forest-600 hover:underline">Ver todos os conceitos →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-forest-600">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Conceito</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider">Broader</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider">Narrower</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider">Related</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% concepts.forEach(c => {
              const label = c.prefLabels && c.prefLabels[0] ? c.prefLabels[0].literalForm : c._id.toString();
              const statusColor = c.status === 'active' ? 'bg-green-100 text-green-800' : c.status === 'candidate' ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-600';
            %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= label %>
              </td>
              <td class="px-4 py-3">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= statusColor %>">
                  <%= c.status %>
                </span>
              </td>
              <td class="px-4 py-3 text-center text-sm text-blue-700 font-medium">
                <%= (c.broader || []).length || '—' %>
              </td>
              <td class="px-4 py-3 text-center text-sm text-indigo-700 font-medium">
                <%= (c.narrower || []).length || '—' %>
              </td>
              <td class="px-4 py-3 text-center text-sm text-purple-700 font-medium">
                <%= (c.related || []).length || '—' %>
              </td>
              <td class="px-4 py-3 text-sm">
                <a href="/concepts/<%= c._id %>"
                   class="text-forest-600 hover:text-forest-800 hover:underline text-sm">
                  Editar
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <% } %>

  </main>

  <%- include('partials/footer') %>
</body>
</html>
