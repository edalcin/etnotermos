<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logs de Aquisição | BioCultTermos Admin</title>
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"
          integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+"
          crossorigin="anonymous" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js"
          integrity="sha384-9Ax3MmS9AClxJyd5/zafcXXjxmwFhZCdsT6HJoJjarvCaAkJlk5QDzjLJm+Wdx5F"
          crossorigin="anonymous" defer></script>
</head>
<body class="bg-forest-50 min-h-screen flex flex-col">
  <%- include('../partials/header') %>

  <main class="flex-grow container mx-auto px-4 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-forest-700">Logs de Aquisição</h1>
        <p class="text-gray-500 text-sm mt-1">
          Histórico de execuções da varredura automática do BioCultDB
        </p>
      </div>

      <!-- Live status polling: active while an acquisition is running -->
      <% if (typeof acquisitionRunning !== 'undefined' && acquisitionRunning) { %>
      <div
        id="acq-live"
        hx-get="/acquisition/status"
        hx-trigger="every 3s"
        hx-swap="outerHTML"
        class="flex items-center gap-2 px-4 py-2 bg-yellow-100 text-yellow-800 rounded-lg text-sm font-medium">
        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        Aquisição em andamento…
      </div>
      <% } %>
    </div>

    <!-- Status filter -->
    <div class="bg-white rounded-lg shadow-sm p-4 mb-6 flex gap-3">
      <a href="/acquisition"
         class="px-4 py-2 rounded-lg text-sm font-medium transition-colors
                <%= !filters || !filters.status ? 'bg-forest-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
        Todos
      </a>
      <a href="/acquisition?status=success"
         class="px-4 py-2 rounded-lg text-sm font-medium transition-colors
                <%= (filters && filters.status === 'success') ? 'bg-forest-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
        Sucesso
      </a>
      <a href="/acquisition?status=failure"
         class="px-4 py-2 rounded-lg text-sm font-medium transition-colors
                <%= (filters && filters.status === 'failure') ? 'bg-forest-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
        Falha
      </a>
    </div>

    <% if (!logs || logs.length === 0) { %>
    <div class="bg-white rounded-lg shadow-sm p-10 text-center text-gray-500">
      Nenhum log de aquisição encontrado.
    </div>
    <% } else { %>
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-forest-600 text-white">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider">Data</th>
            <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider">Status</th>
            <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider">Criados</th>
            <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider">Existentes</th>
            <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider hidden sm:table-cell">
              Duração
            </th>
            <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider">Detalhes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% logs.forEach(log => { %>
          <tr class="hover:bg-forest-50 transition-colors" x-data="{ open: false }">
            <td class="px-5 py-3 text-sm text-gray-700 whitespace-nowrap">
              <%= new Date(log.executedAt).toLocaleString('pt-BR') %>
            </td>
            <td class="px-5 py-3">
              <% if (log.status === 'success' && !log.hasUnresolved) { %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 text-green-800
                           rounded-full text-xs font-medium">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"/>
                </svg>
                Sucesso
              </span>
              <% } else { %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-100 text-red-800
                           rounded-full text-xs font-medium">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd"
                        d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                        clip-rule="evenodd"/>
                </svg>
                Falha
              </span>
              <% } %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-700 text-right font-mono">
              <%= log.conceptsCreated %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500 text-right font-mono">
              <%= log.conceptsExisting %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500 text-right hidden sm:table-cell">
              <%= log.durationMs ? (log.durationMs / 1000).toFixed(1) + 's' : '—' %>
            </td>
            <td class="px-5 py-3 text-right">
              <% if (log.errors && log.errors.length > 0) { %>
              <button @click="open = !open"
                      class="text-sm text-forest-600 hover:text-forest-800 underline">
                Ver erros (<%= log.errors.length %>)
              </button>
              <% } else { %>
              <span class="text-xs text-gray-400">—</span>
              <% } %>
            </td>
          </tr>

          <!-- Expandable errors row -->
          <% if (log.errors && log.errors.length > 0) { %>
          <tr x-show="open" x-cloak>
            <td colspan="6" class="px-5 py-4 bg-red-50">
              <p class="text-xs font-semibold text-red-700 mb-2 uppercase tracking-wide">
                Erros da execução
              </p>
              <ul class="space-y-1">
                <% log.errors.forEach(err => { %>
                <li class="text-sm text-red-800 font-mono">
                  <%= typeof err === 'string' ? err : JSON.stringify(err) %>
                </li>
                <% }) %>
              </ul>
              <% if (log.errorMessage) { %>
              <p class="mt-2 text-sm text-red-800"><strong>Mensagem:</strong> <%= log.errorMessage %></p>
              <% } %>
            </td>
          </tr>
          <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
