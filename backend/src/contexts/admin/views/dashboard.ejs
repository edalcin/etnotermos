<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | EtnoTermos Admin</title>
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"
          integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+"
          crossorigin="anonymous" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js"
          integrity="sha384-9Ax3MmS9AClxJyd5/zafcXXjxmwFhZCdsT6HJoJjarvCaAkJlk5QDzjLJm+Wdx5F"
          crossorigin="anonymous" defer></script>
</head>
<body class="bg-forest-50 min-h-screen flex flex-col">
  <%- include('partials/header') %>

  <main class="flex-grow container mx-auto px-4 py-8">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-forest-700 mb-1">Dashboard</h1>
      <p class="text-gray-500">Visão geral do vocabulário controlado SKOS-XL</p>
    </div>

    <!-- Acquisition failure alert -->
    <% if (typeof lastAcq !== 'undefined' && lastAcq && (lastAcq.status === 'failure' || lastAcq.hasUnresolved)) { %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-8 rounded-r-lg flex items-start gap-3">
      <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <div>
        <p class="font-semibold text-red-800">Problema na última aquisição</p>
        <p class="text-red-700 text-sm mt-1">
          Falha em
          <%= new Date(lastAcq.executedAt).toLocaleString('pt-BR') %>.
          <a href="/acquisition" class="underline font-medium">Verifique os logs.</a>
        </p>
      </div>
    </div>
    <% } %>

    <!-- Status count cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
        <div class="text-3xl font-bold text-yellow-700"><%= stats.candidate || 0 %></div>
        <div class="text-yellow-800 font-medium mt-1">Candidatos</div>
        <div class="text-yellow-600 text-sm mt-1">Aguardando revisão</div>
        <a href="/concepts?status=candidate"
           class="inline-block mt-3 text-sm text-yellow-700 underline hover:text-yellow-900">
          Ver candidatos →
        </a>
      </div>

      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <div class="text-3xl font-bold text-green-700"><%= stats.active || 0 %></div>
        <div class="text-green-800 font-medium mt-1">Ativos</div>
        <div class="text-green-600 text-sm mt-1">Termos aprovados</div>
        <a href="/concepts?status=active"
           class="inline-block mt-3 text-sm text-green-700 underline hover:text-green-900">
          Ver ativos →
        </a>
      </div>

      <div class="bg-gray-100 border border-gray-200 rounded-lg p-6">
        <div class="text-3xl font-bold text-gray-600"><%= stats.deprecated || 0 %></div>
        <div class="text-gray-700 font-medium mt-1">Depreciados</div>
        <div class="text-gray-500 text-sm mt-1">Fora de uso</div>
        <a href="/concepts?status=deprecated"
           class="inline-block mt-3 text-sm text-gray-600 underline hover:text-gray-800">
          Ver depreciados →
        </a>
      </div>
    </div>

    <!-- Acquisition trigger -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-800 mb-3">Aquisição de Termos</h2>
      <p class="text-gray-600 text-sm mb-4">
        Varre o banco etnoDB e cria conceitos candidatos para valores de campo ainda não catalogados.
      </p>

      <button
        hx-post="/acquisition/run"
        hx-target="#acq-status"
        hx-swap="innerHTML"
        hx-indicator="#acq-spinner"
        class="px-5 py-2 bg-forest-600 text-white rounded-lg hover:bg-forest-700
               transition-colors font-medium flex items-center gap-2">
        <svg id="acq-spinner"
             class="htmx-indicator w-4 h-4 animate-spin"
             fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor"
                d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        Executar Aquisição
      </button>

      <div id="acq-status" class="mt-3 text-sm text-gray-600"></div>
    </div>

    <!-- Quick links -->
    <div class="flex flex-wrap gap-4">
      <a href="/concepts"
         class="px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm
                hover:border-forest-400 hover:shadow-md transition-all text-gray-700">
        Ver todos os termos
      </a>
      <a href="/acquisition"
         class="px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm
                hover:border-forest-400 hover:shadow-md transition-all text-gray-700">
        Logs de aquisição
      </a>
      <a href="/audit"
         class="px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm
                hover:border-forest-400 hover:shadow-md transition-all text-gray-700">
        Auditoria
      </a>
    </div>

  </main>

  <%- include('partials/footer') %>
</body>
</html>
