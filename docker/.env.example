# Copy this file to docker/.env and fill in the values before running docker-compose.
#
# Generate a bcrypt hash for ADMIN_USERS:
#   node -e "const b=require('bcrypt'); b.hash('suasenha',10).then(h=>console.log(h))"
#
# Then set ADMIN_USERS as a JSON array:
#   ADMIN_USERS=[{"username":"curador1","passwordHash":"$2b$10$HASH_AQUI"}]

# Optional: SQLite file path (default /data/unidade-dev.sqlite inside the container).
# Em produção (unidade federada v3.1), aponta ao arquivo compartilhado com o BioCultDB.
SQLITE_DB_PATH=/data/unidade-dev.sqlite

# Required: admin users (JSON array, bcrypt hashes)
ADMIN_USERS=[{"username":"curador1","passwordHash":"$2b$10$SUBSTITUIR_HASH_AQUI"}]

# Optional overrides
ACQUISITION_CRON_SCHEDULE=0 3 * * *
LOG_LEVEL=info

# URL pública do BioCultDB (interface de busca) — usada nos links de fontes bibliográficas
BIOCULTDB_PUBLIC_URL=http://localhost:3003
